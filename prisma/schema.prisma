// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  class          String
  password       String
  role           String            @default("student")
  streakCount    Int               @default(0)
  lastActiveDate DateTime          @default(now())
  createdAt      DateTime          @default(now())
  progress       UserProgress[]
  chapterProgress ChapterProgress[]
}

model Subject {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  class    String
  chapters Chapter[]

  @@unique([name, class])
}

model Chapter {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subjectId   String       @db.ObjectId
  orderIndex  Int
  writtenQuestion String?
  
  subject     Subject      @relation(fields: [subjectId], references: [id])
  lessons     Lesson[]
  supplements Supplement[]
  quiz        Quiz?
  progress    ChapterProgress[]
}

model Quiz {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  chapterId String     @unique @db.ObjectId
  questions Question[]
  chapter   Chapter    @relation(fields: [chapterId], references: [id])
}

model Question {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  quizId        String   @db.ObjectId
  text          String
  options       String[] // 4 options
  correctAnswer Int      // index 0-3
  imageUrl      String?  // For visual quizzes
  explanation   String?
  
  quiz          Quiz     @relation(fields: [quizId], references: [id])
}

model Lesson {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  chapterId String         @db.ObjectId
  title     String
  videoUrl  String
  
  chapter   Chapter        @relation(fields: [chapterId], references: [id])
  progress  UserProgress[]
}

model Supplement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  chapterId String   @db.ObjectId
  title     String
  link      String
  type      String   // book, pdf, resource
  
  chapter   Chapter  @relation(fields: [chapterId], references: [id])
}

model UserProgress {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  lessonId         String   @db.ObjectId
  videoCompleted   Boolean  @default(false)
  quizCompleted    Boolean  @default(false)
  writtenCompleted Boolean  @default(false)
  mastery          Float    @default(0) // 0-100
  completedAt      DateTime?
  updatedAt        DateTime @updatedAt
  
  user             User     @relation(fields: [userId], references: [id])
  lesson           Lesson   @relation(fields: [lessonId], references: [id])
  
  @@unique([userId, lessonId])
}

model ChapterProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  chapterId   String   @db.ObjectId
  mastery          Float    @default(0) // 0-100
  quizCompleted    Boolean  @default(false)
  writtenCompleted Boolean  @default(false)
  isCompleted      Boolean  @default(false)
  
  user        User     @relation(fields: [userId], references: [id])
  chapter     Chapter  @relation(fields: [chapterId], references: [id])
  
  @@unique([userId, chapterId])
}
